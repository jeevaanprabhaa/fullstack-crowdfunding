# ── Frontend (Vercel) ──────────────────────────────────────────
# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Stripe (publishable key — safe to expose on frontend)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Your Render backend URL (e.g. https://crowdup-api.onrender.com)
VITE_API_URL=https://your-render-service.onrender.com

# ── Backend (Render) ───────────────────────────────────────────
# Stripe secret key — NEVER expose this on the frontend
STRIPE_SECRET_KEY=sk_live_...

# Comma-separated list of allowed frontend origins
# e.g. https://your-app.vercel.app,https://yourdomain.com
ALLOWED_ORIGIN=https://your-app.vercel.app

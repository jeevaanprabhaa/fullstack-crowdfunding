# ── Frontend environment variables (set these on Vercel) ──────────────────────

# Your Render backend URL — REQUIRED for the frontend to reach the API on Vercel
# e.g. https://crowdup-api.onrender.com  (no trailing slash)
VITE_API_URL=https://your-render-service.onrender.com

# Stripe publishable key — safe to expose, used in the browser
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ── Backend environment variables (set these on Render) ───────────────────────

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Secret used to sign JWT tokens — generate a long random string
JWT_SECRET=replace-with-a-long-random-secret

# Stripe secret key — NEVER expose this in the frontend
STRIPE_SECRET_KEY=sk_live_...

# Comma-separated list of allowed frontend origins (your Vercel URLs)
# e.g. https://crowdup.vercel.app,https://crowdup-git-main.vercel.app
ALLOWED_ORIGIN=https://your-app.vercel.app
